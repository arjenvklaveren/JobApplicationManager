generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id Int @default(autoincrement()) @id
  name String @unique
  password String
  applicant Applicant?

  //Explicit data relationship declarations
  companies Company[]
  positions Position[]
  applications Application[]
  notes Note[]
}

model Applicant {
  id Int @default(autoincrement()) @id
  city String
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int @unique
  applications Application[]
}

model Company {
  id Int @default(autoincrement()) @id
  name String
  city String
  websiteUrl String
  positions Position[]

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model Position {
  id Int @default(autoincrement()) @id
  title String
  sourceUrl String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int 
  application Application?

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model Application { 
  id Int @default(autoincrement()) @id
  applied_date DateTime
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId Int @unique
  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  applicantId Int

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model Note {
  id Int @default(autoincrement()) @id
  title String
  information String

  targetId Int
  targetType NoteTargetType

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

enum NoteTargetType {
  COMPANY
  POSITION
  APPLICATION
}