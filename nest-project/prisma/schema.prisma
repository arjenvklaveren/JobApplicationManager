generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id Int @default(autoincrement()) @id
  name String @unique
  password String
  applicant Applicant?

  //Explicit data relationship declarations
  companies Company[]
  positions Position[]
  applications Application[]
  tasks Task[]
  notes Note[]
  appointments Appointment[]
  contactpeople ContactPerson[]
}

model Applicant {
  id Int @default(autoincrement()) @id
  city String
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int @unique
  applications Application[]
}

model Company {
  id Int @default(autoincrement()) @id
  name String
  city String
  websiteUrl String
  positions Position[]
  appointments Appointment[]
  contact ContactPerson?
  isAgency Boolean @default(false)

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model Position {
  id Int @default(autoincrement()) @id
  title String
  sourceUrl String
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int 
  application Application?

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model Application { 
  id Int @default(autoincrement()) @id
  applied_date DateTime
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId Int @unique
  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  applicantId Int

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

enum ApplicationStatus {
  ONGOING
  ACCEPTED
  REJECTED
}

model Note {
  id Int @default(autoincrement()) @id
  title String
  information String

  targetId Int
  targetType NoteTargetType

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

enum NoteTargetType {
  COMPANY
  POSITION
  APPLICATION
  APPOINTMENT
}

model Task {
  id Int @default(autoincrement()) @id
  name String
  description String
  stage Int
  index Int
  deadline DateTime?
  
  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model Appointment {
  id Int @default(autoincrement()) @id
  location String
  time DateTime?
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int?

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}

model ContactPerson { 
  id Int @default(autoincrement()) @id
  name String
  position String
  email String?
  phone String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int @unique

  //Acount reference
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId Int
}